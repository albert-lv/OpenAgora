# Kimi Code CLI LLM backend.
# Build context: repo root.
FROM node:20-slim

# Install Python for the FastAPI proxy.
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install the Kimi Code CLI binary to a shared, executable location as root.
# The install script resolves the latest version and downloads the matching
# binary; we then move it to /usr/local/bin so the unprivileged agent user
# can execute it.
RUN curl -fsSL https://code.kimi.com/kimi-code/install.sh | bash \
    && mkdir -p /usr/local/bin \
    && cp /root/.kimi-code/bin/kimi /usr/local/bin/kimi \
    && chmod +x /usr/local/bin/kimi

# Kimi CLI may refuse to run as root in some modes.
RUN useradd -m -s /bin/bash agent
USER agent
WORKDIR /home/agent

COPY --chown=agent:agent examples/code-colosseum/agent/requirements.kimi.txt /app/requirements.txt
COPY --chown=agent:agent examples/code-colosseum/agent/kimi_llm.py /app/llm.py

RUN pip3 install --break-system-packages --user -r /app/requirements.txt

ENV KIMI_TIMEOUT=120
ENV PATH="/home/agent/.local/bin:/usr/local/bin:${PATH}"
EXPOSE 8000

ENTRYPOINT ["python3", "-u", "/app/llm.py"]
