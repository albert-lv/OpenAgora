# OpenCode LLM backend — proxies to Kimi Code API via OpenAI-compatible interface.
# Build context: repo root.
FROM python:3.11-slim

WORKDIR /app

COPY examples/code-colosseum/agent/requirements.kimi.txt /app/requirements.txt
COPY examples/code-colosseum/agent/opencode_llm.py /app/llm.py

RUN pip install --no-cache-dir -r /app/requirements.txt

ENV KIMI_API_KEY=""
ENV KIMI_BASE_URL=https://api.kimi.com/coding/v1
ENV KIMI_MODEL=kimi-for-coding

EXPOSE 8000

ENTRYPOINT ["python3", "-u", "/app/llm.py"]
