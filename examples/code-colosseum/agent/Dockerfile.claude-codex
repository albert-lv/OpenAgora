# Shared image for Claude Code and OpenAI Codex LLM backends.
# Two services are spawned from this image with MODEL_PROVIDER=claude or codex.
# Build context: repo root.
FROM node:20-slim

# Install Python so we can run the FastAPI proxy.
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

# Install the coding agent CLIs.
RUN npm install -g @anthropic-ai/claude-code @openai/codex

# Claude Code refuses to run with --dangerously-skip-permissions as root.
RUN useradd -m -s /bin/bash agent
USER agent
WORKDIR /home/agent

COPY --chown=agent:agent examples/code-colosseum/agent/claude_codex_llm.py /app/llm.py
COPY --chown=agent:agent examples/code-colosseum/agent/requirements.claude-codex.txt /app/requirements.txt

RUN pip3 install --break-system-packages --user -r /app/requirements.txt

ENV MODEL_PROVIDER=claude
ENV PATH="/home/agent/.local/bin:${PATH}"
EXPOSE 8000

ENTRYPOINT ["python3", "-u", "/app/llm.py"]
