FROM python:3.12-slim

# Place the agent script outside the /sandbox bind-mount so it is not shadowed.
WORKDIR /app

# Minimal agent — reads task.json, loops on LLM calls, writes done on completion
COPY <<'EOF' /app/agent.py
import json
import os
import time
import urllib.request


def main():
    base_url = os.environ.get("OPENAI_BASE_URL", "").rstrip("/")
    token = os.environ.get("ARENA_ROLLOUT_TOKEN", "")
    task_id = os.environ.get("ARENA_TASK_ID", "unknown")

    print(f"Task: {task_id}")
    print(f"Proxy: {base_url}")

    if not base_url:
        print("OPENAI_BASE_URL not set, skipping LLM calls")

    for i in range(2):
        if not base_url:
            break
        req = urllib.request.Request(
            f"{base_url}/chat/completions",
            data=json.dumps({"model": "gpt-4", "messages": []}).encode(),
            headers={
                "Authorization": f"Bearer {token}",
                "Content-Type": "application/json",
            },
            method="POST",
        )
        try:
            with urllib.request.urlopen(req, timeout=10) as resp:
                data = json.loads(resp.read().decode())
                choices = data.get("choices", [])
                content = choices[0]["message"]["content"] if choices else ""
                print(f"Call {i + 1}: {content}")
        except Exception as e:
            print(f"Call {i + 1} failed: {e}")
        time.sleep(0.1)

    os.makedirs("/sandbox/.arena", exist_ok=True)
    with open("/sandbox/.arena/done", "w") as f:
        f.write(json.dumps({"status": "success"}))


if __name__ == "__main__":
    main()
EOF

# Sandboxes receive a bind-mount at /sandbox, so keep that as the working dir.
WORKDIR /sandbox
CMD ["python3", "/app/agent.py"]
